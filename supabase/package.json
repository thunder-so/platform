{
  "name": "supabase-functions",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "deploy:prod:notification-webhook": "supabase functions deploy notification-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID",
    "deploy:prod:github-webhook": "supabase functions deploy github-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID",
    "deploy:prod:polar-webhook": "supabase functions deploy polar-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID",
    "deploy:prod:resend-audience-webhook": "supabase functions deploy resend-audience-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID",
    "deploy:sandbox:notification-webhook": "supabase functions deploy notification-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID",
    "deploy:sandbox:github-webhook": "supabase functions deploy github-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID",
    "deploy:sandbox:polar-webhook": "supabase functions deploy polar-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID",
    "deploy:sandbox:resend-audience-webhook": "supabase functions deploy resend-audience-webhook --no-verify-jwt --project-ref $SUPABASE_PROJECT_ID"
