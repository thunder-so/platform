{
  "name": "console",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:pull": "dotenv -e .env --  npx drizzle-kit introspect",
    "db:generate": "dotenv -e .env -- npx drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- npx drizzle-kit migrate",
    "deploy:sandbox": "dotenv -e .env -- cdk deploy --all --app=\"npx tsx stack/sandbox.ts\" --profile burner"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.911.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.911.0",
    "@aws-sdk/client-route-53": "^3.911.0",
    "@aws-sdk/client-sqs": "^3.911.0",
    "@aws-sdk/client-ssm": "^3.911.0",
    "@aws-sdk/client-sts": "^3.911.0",
    "@aws-sdk/client-secrets-manager": "^3.911.0",
    "@aws-sdk/core": "^3.911.0",
    "@nuxt/icon": "2.0.0",
    "@nuxt/kit": "^4.1.3",
    "@nuxt/ui": "^4.0.0-alpha.1",
    "@nuxtjs/supabase": "1.5.3",
    "@nuxtjs/tailwindcss": "^7.0.0-beta.0",
    "@octokit/app": "^16.1.0",
    "@octokit/auth-app": "^8.1.0",
    "@octokit/core": "^7.0.3",
    "@octokit/types": "^14.1.0",
    "@polar-sh/nuxt": "^0.3.11",
    "@thunderso/cdk-nuxt": "^0.2.0",
    "@trpc/client": "^11.5.0",
    "@trpc/server": "^11.5.0",
    "drizzle-cuid2": "^2.1.0",
    "drizzle-orm": "^0.44.5",
    "lodash-es": "^4.17.21",
    "nuxt": "^4.1.3",
    "pg": "^8.16.3",
    "superjson": "^2.2.2",
    "trpc-nuxt": "^1.2.0",
    "tsx": "^4.20.6",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/pg": "^8.15.5",
    "dotenv": "^17.2.2",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "^0.31.4"
