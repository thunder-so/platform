{
  "name": "@thunderso/platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy": "turbo run deploy",
    "build:console": "turbo run build --filter=console",
    "build:services": "turbo run build --filter=services",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --verbose"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "turbo": "^2.6.1",
    "supabase": "^2.62.5"
  },
  "workspaces": [
    "packages/*",
    "services",
    "services/*"
  ],
  "packageManager": "bun@1.3.3"
}