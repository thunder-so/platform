{
  "name": "@thunder-so/platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy": "turbo run deploy",
    "build:console": "turbo run build --filter=thunder-console",
    "build:services": "turbo run build --filter=thunder-services"
  },
  "devDependencies": {
    "turbo": "^2.6.1",
    "supabase": "^2.62.5",
    "@supabase/supabase-js": "2.86.0",
    "@thunder-so/thunder": "github:thunder-so/thunder#v1.4.7"
  },
  "workspaces": [
    "apps/*",
    "services",
    "services/*",
    "supabase"
  ],
  "packageManager": "bun@1.3.10"
}